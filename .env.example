# Copy to .env and fill these in. .env is gitignored; NEVER commit real keys.

# --- Vision / enrichment (OpenRouter) --------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
# Any vision-capable OpenRouter model slug works.
# Swap to google/gemini-flash-1.5 (cheaper/faster) later if you like.
VISION_MODEL=openai/gpt-4o
# Optional: model used for ingredients + history generation. Defaults to VISION_MODEL.
# ENRICHMENT_MODEL=openai/gpt-4o-mini

# --- Embeddings (OpenAI) ---------------------------------------------------
# Used for semantic dish search and matching recognised names to the dataset.
OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# --- Database (Neon Postgres with pgvector) --------------------------------
# Create a free project at https://neon.tech and paste the pooled connection
# string (sslmode=require). The app will run without this, but search, login,
# saved dishes, and corrections will be disabled.
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# --- Google sign-in --------------------------------------------------------
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Application type: Web application.
# Authorized redirect URI: ${PUBLIC_URL}/auth/google/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# --- Sessions + deployment -------------------------------------------------
# 32+ random bytes used to sign the hl_sess cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=replace-me-with-32-plus-random-bytes

# Public origin of your deployment (no trailing slash).
# Used to construct the Google OAuth redirect URI.
PUBLIC_URL=http://localhost:3000
